{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capability.json",
  "identifier": "default",
  "description": "Default permissions for ADA Desktop",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ada-api",
          "sidecar": true
        },
        {
          "name": "ada-api",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/ada-api",
          "sidecar": true
        },
        {
          "name": "ada-api",
          "sidecar": true
        }
      ]
    }
  ]
}
