{
  "$schema": "../node_modules/@tauri-apps/cli/schema/config.json",
  "productName": "ADA Desktop",
  "version": "1.0.0",
  "identifier": "com.ada.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADA Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/ada-api"
    ]
  },
  "plugins": {
    "shell": {
      "sidecar": {
        "ada-api": {
          "args": [],
          "options": {}
        }
      }
    }
  }
}
